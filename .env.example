# Variáveis de ambiente para produção
# Copie este arquivo para .env e preencha os valores

# URL base da aplicação (ajuste conforme necessário)
# Exemplo: http://localhost:4000 para desenvolvimento local ou https://seu-dominio.com para produção
APP_URL=

# Chave da API do Google AI Studio
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GOOGLE_AI_STUDIO_API_KEY

# JWT Secret - MUDE ISTO para uma string aleatória forte em produção
JWT_SECRET=finflow-prod-secret-change-this-in-production

# Ambiente (development ou production)
NODE_ENV=production

# Porta do servidor (opcional, padrão 4000)
PORT=4000

# Chave da API do Resend (para envio de e-mails)
# Obtenha em: https://resend.com/dashboard/api-keys
RESEND_API_KEY=

# Cloudflare Turnstile (anti-bot) — obtenha em dash.cloudflare.com → Turnstile
# Deixe em branco para desativar a verificação (não recomendado em produção)
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=