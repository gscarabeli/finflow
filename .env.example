# ─── Banco de dados ───────────────────────────────────────────────────────────
# String de conexão do Supabase (Settings > Database > Connection String > URI)
# Formato: postgresql://postgres:[senha]@[host].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[SUA-SENHA]@[SEU-HOST].supabase.co:5432/postgres

# ─── Autenticação ─────────────────────────────────────────────────────────────
# JWT Secret — gere com: openssl rand -hex 32
JWT_SECRET=troque-por-uma-string-aleatoria-forte

# ─── Controle de acesso ───────────────────────────────────────────────────────
# Liste os e-mails autorizados separados por vírgula
# Deixe em branco para permitir qualquer cadastro (só para desenvolvimento)
ALLOWED_EMAILS=voce@email.com,suanamorada@email.com

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL=https://seu-dominio.onrender.com
NODE_ENV=production
PORT=4000

# ─── E-mail (Resend) ──────────────────────────────────────────────────────────
# Obtenha em: https://resend.com/dashboard/api-keys
RESEND_API_KEY=re_...

# ─── IA (Google Gemini) ───────────────────────────────────────────────────────
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# ─── Anti-bot (Cloudflare Turnstile) ─────────────────────────────────────────
# Crie em: https://dash.cloudflare.com → Turnstile
# Deixe em branco para desativar (não recomendado em produção)
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
